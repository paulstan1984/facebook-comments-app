<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageName %> – Posts</title>
  <%- include('partials/_styles') %>
  <style>
    /* Loading overlay shown while the CSV is being generated */
    #loading-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 100;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
      color: #fff;
      font-size: 1rem;
    }
    #loading-overlay.visible { display: flex; }
    .spinner {
      width: 40px; height: 40px;
      border: 4px solid rgba(255,255,255,.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin .8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .comment-count {
      font-size: .875rem;
      color: #555;
    }
    .post-actions {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: .5rem;
    }
    .btn-winner { background: #f5a623; color: #fff; }
    #winner-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.55);
      z-index: 200;
      align-items: center;
      justify-content: center;
    }
    #winner-modal.visible { display: flex; }
    .winner-box {
      background: #fff;
      border-radius: 12px;
      padding: 32px;
      max-width: 480px;
      width: 90%;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0,0,0,.25);
    }
    .winner-trophy { font-size: 3rem; display: block; margin-bottom: 12px; }
    .winner-box h2 { font-size: 1.3rem; margin-bottom: 4px; }
    .winner-name { font-size: 1.15rem; font-weight: 700; margin: 12px 0 6px; color: #1877F2; }
    .winner-comment { font-size: .95rem; color: #444; line-height: 1.5; margin-bottom: 16px; }
    .winner-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
    .pagination {
      display: flex;
      gap: .75rem;
      justify-content: center;
      margin: 1.5rem 0;
    }
  </style>
</head>
<body>
  <!-- Loading overlay (shown while comments are being fetched) -->
  <div id="loading-overlay" role="status" aria-live="polite">
    <div class="spinner"></div>
    <span>Fetching all comments&hellip; this may take a moment.</span>
  </div>

  <!-- Winner modal -->
  <div id="winner-modal" role="dialog" aria-modal="true" aria-labelledby="winner-title">
    <div class="winner-box">
      <span class="winner-trophy">&#127942;</span>
      <h2 id="winner-title">Winner!</h2>
      <p class="winner-name" id="winner-name"></p>
      <p class="winner-comment" id="winner-comment"></p>
      <div class="winner-actions">
        <a id="winner-link" href="#" target="_blank" rel="noopener noreferrer" class="btn btn-primary">View Comment</a>
        <button id="winner-close" class="btn btn-muted">Close</button>
      </div>
    </div>
  </div>

  <%- include('partials/_nav') %>

  <main>
    <a href="/pages" class="back-link">&#8592; Back to Pages</a>

    <h1 class="page-title">Posts &ndash; <%= pageName %></h1>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="alert alert-info">
      Showing 30 posts per page. Click <strong>Download CSV</strong> to export
      all comments for that post as a three-column spreadsheet (Name, Comment, Link).
    </div>

    <% if (posts.length === 0) { %>
      <div class="card">
        <p class="empty">No posts found for this page.</p>
      </div>
    <% } else { %>
      <% for (const post of posts) { %>
        <%
          const rawText = post.message || post.story || '(No text)';
          const date = new Date(post.created_time).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric'
          });
        %>
        <div class="card post-card">
          <div class="post-body">
            <p class="post-message"><%= rawText %></p>
            <p class="post-date">
              <%= date %>
              <% const commentCount = post.comments?.summary?.total_count; %>
              <% if (commentCount != null) { %>
                &mdash; &#128172;&nbsp;<%= commentCount %> comment<%= commentCount !== 1 ? 's' : '' %>
              <% } %>
              <% if (post.permalink_url) { %>
                &mdash; <a href="<%- post.permalink_url %>" target="_blank" rel="noopener noreferrer">View on Facebook</a>
              <% } %>
            </p>
          </div>
          <div class="post-actions">
            <a
              href="/export/<%= pageId %>/<%= post.id %>"
              class="btn btn-success export-btn"
            >&#8681;&nbsp;Download CSV</a>
            <button
              class="btn btn-winner winner-btn"
              data-page-id="<%= pageId %>"
              data-post-id="<%= post.id %>"
            >&#127942;&nbsp;Choose Winner</button>
            <a
              class="btn btn-primary view-winner-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              style="display:none"
            >&#127942;&nbsp;View the Winner</a>
          </div>
        </div>
      <% } %>
    <% } %>

    <div class="pagination">
      <% if (!isFirstPage) { %>
        <a href="/pages/<%= pageId %>/posts" class="btn">&#8592; First page</a>
      <% } %>
      <% if (nextCursor) { %>
        <a href="/pages/<%= pageId %>/posts?after=<%= encodeURIComponent(nextCursor) %>" class="btn">Next page &#8594;</a>
      <% } %>
    </div>
  </main>

  <script src="/posts.js"></script>
</body>
</html>
