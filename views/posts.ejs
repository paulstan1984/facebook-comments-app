<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageName %> – Posts</title>
  <%- include('partials/_styles') %>
  <style>
    .post-actions {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: .5rem;
    }
    .btn-winner { background: #f5a623; color: #fff; }
    #winner-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.55);
      z-index: 200;
      align-items: center;
      justify-content: center;
    }
    #winner-modal.visible { display: flex; }
    .winner-box {
      background: #fff;
      border-radius: 12px;
      padding: 32px;
      max-width: 480px;
      width: 90%;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0,0,0,.25);
    }
    .winner-trophy { font-size: 3rem; display: block; margin-bottom: 12px; }
    .winner-box h2 { font-size: 1.3rem; margin-bottom: 4px; }
    .winner-name { font-size: 1.15rem; font-weight: 700; margin: 12px 0 6px; color: #1877F2; }
    .winner-comment { font-size: .95rem; color: #444; line-height: 1.5; margin-bottom: 16px; }
    .winner-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
    .pagination {
      display: flex;
      gap: .75rem;
      justify-content: center;
      margin: 1.5rem 0;
    }
  </style>
</head>
<body>
  <!-- Winner modal -->
  <div id="winner-modal" role="dialog" aria-modal="true" aria-labelledby="winner-title">
    <div class="winner-box">
      <span class="winner-trophy">&#127942;</span>
      <h2 id="winner-title">Winner!</h2>
      <p class="winner-comment" id="winner-comment"></p>
      <div class="winner-actions">
        <a id="winner-link" href="#" target="_blank" rel="noopener noreferrer" class="btn btn-primary">View Comment</a>
        <button id="winner-close" class="btn btn-muted">Close</button>
      </div>
    </div>
  </div>

  <%- include('partials/_nav') %>

  <main>
    <a href="/pages" class="back-link">&#8592; Back to Pages</a>

    <h1 class="page-title">Posts &ndash; <%= pageName %></h1>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="alert alert-info">
      Showing 10 posts per page.
    </div>

    <form method="get" action="/pages/<%= pageId %>/posts" style="margin-bottom:1rem;display:flex;gap:.5rem;align-items:center;">
      <label for="date-filter" style="font-size:.9rem;font-weight:600;">Filter by date:</label>
      <input
        type="date"
        id="date-filter"
        name="date"
        value="<%= selectedDate %>"
        style="padding:6px 10px;border:1px solid #ccc;border-radius:6px;font-size:.9rem;"
      >
      <button type="submit" class="btn btn-primary" style="padding:6px 16px;">Apply</button>
      <% if (selectedDate) { %>
        <a href="/pages/<%= pageId %>/posts" class="btn btn-muted" style="padding:6px 16px;">Clear</a>
      <% } %>
    </form>

    <div class="pagination">
      <% if (!isFirstPage) { %>
        <a href="/pages/<%= pageId %>/posts<%= selectedDate ? '?date=' + selectedDate : '' %>" class="btn">&#8592; First page</a>
      <% } %>
      <% if (nextCursor) { %>
        <a href="/pages/<%= pageId %>/posts?after=<%= encodeURIComponent(nextCursor) %><%= selectedDate ? '&date=' + selectedDate : '' %>" class="btn">Next page &#8594;</a>
      <% } %>
    </div>

    <% if (posts.length === 0) { %>
      <div class="card">
        <p class="empty">No posts found for this page.</p>
      </div>
    <% } else { %>
      <% for (const post of posts) { %>
        <%
          const rawText = post.message || post.story || '(No text)';
          const date = new Date(post.created_time).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric'
          });
        %>
        <div class="card post-card">
          <% if (post.full_picture) { %>
            <img src="<%- post.full_picture %>" alt="Post image" class="post-image">
          <% } %>
          <div class="post-card-body">
            <div class="post-body">
              <p class="post-message"><%= rawText %></p>
              <p class="post-date">
                <%= date %>
                <% const commentCount = post.comments?.summary?.total_count; %>
                <% if (commentCount != null) { %>
                  &mdash; &#128172;&nbsp;<%= commentCount %> comment<%= commentCount !== 1 ? 's' : '' %>
                <% } %>
                <% if (post.permalink_url) { %>
                  &mdash; <a href="<%- post.permalink_url %>" target="_blank" rel="noopener noreferrer">View on Facebook</a>
                <% } %>
              </p>
            </div>
            <div class="post-actions">
              <button
                class="btn btn-winner winner-btn"
                data-page-id="<%= pageId %>"
                data-post-id="<%= post.id %>"
              >&#127942;&nbsp;Choose Winner</button>
              <a
                class="btn btn-primary view-winner-link"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                style="display:none"
              >&#127942;&nbsp;View the Winner</a>
            </div>
          </div>
        </div>
      <% } %>
    <% } %>

    <div class="pagination">
      <% if (!isFirstPage) { %>
        <a href="/pages/<%= pageId %>/posts<%= selectedDate ? '?date=' + selectedDate : '' %>" class="btn">&#8592; First page</a>
      <% } %>
      <% if (nextCursor) { %>
        <a href="/pages/<%= pageId %>/posts?after=<%= encodeURIComponent(nextCursor) %><%= selectedDate ? '&date=' + selectedDate : '' %>" class="btn">Next page &#8594;</a>
      <% } %>
    </div>
  </main>

  <script src="/posts.js"></script>
</body>
</html>
