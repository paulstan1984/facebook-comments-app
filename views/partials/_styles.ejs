<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    background: #f0f2f5;
    color: #1c1e21;
    min-height: 100vh;
  }

  /* ── Navigation ── */
  nav {
    background: #1877F2;
    color: #fff;
    height: 56px;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 2px 4px rgba(0,0,0,.2);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  nav .brand { font-size: 1.1rem; font-weight: 700; letter-spacing: .3px; }
  nav .nav-right { display: flex; align-items: center; gap: 16px; font-size: .875rem; }
  nav a { color: #fff; text-decoration: none; }
  nav a:hover { text-decoration: underline; }

  /* ── Layout ── */
  main {
    max-width: 820px;
    margin: 36px auto;
    padding: 0 16px;
  }
  .page-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 20px; }
  .back-link {
    display: inline-block;
    margin-bottom: 18px;
    color: #1877F2;
    text-decoration: none;
    font-size: .875rem;
  }
  .back-link:hover { text-decoration: underline; }

  /* ── Cards ── */
  .card {
    background: #fff;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 16px;
    box-shadow: 0 1px 3px rgba(0,0,0,.1);
  }

  /* ── Alerts ── */
  .alert {
    border-radius: 6px;
    padding: 12px 16px;
    margin-bottom: 20px;
    font-size: .9rem;
  }
  .alert-error { background: #fff0f0; color: #c62828; border: 1px solid #ffcdd2; }
  .alert-info  { background: #e8f4fd; color: #1565c0; border: 1px solid #bbdefb; }

  /* ── Buttons ── */
  .btn {
    display: inline-block;
    padding: 10px 20px;
    border-radius: 6px;
    font-size: .9rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: filter .15s;
  }
  .btn:hover { filter: brightness(.92); }
  .btn-primary  { background: #1877F2; color: #fff; }
  .btn-facebook { background: #1877F2; color: #fff; padding: 12px 24px; font-size: 1rem; }
  .btn-success  { background: #42b72a; color: #fff; }
  .btn-muted    { background: #e4e6ea; color: #1c1e21; }

  /* ── Pages grid ── */
  .pages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }
  .page-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
  }
  .page-pic { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; }
  .page-name { font-weight: 700; font-size: 1rem; }

  /* ── Post list ── */
  .post-card { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
  .post-body { flex: 1; }
  .post-message { font-size: .95rem; line-height: 1.5; color: #1c1e21; margin-bottom: 6px; }
  .post-date    { font-size: .8rem; color: #65676b; }
  .post-actions { flex-shrink: 0; }

  /* ── Hero ── */
  .hero { text-align: center; padding: 48px 24px; }
  .hero h2 { font-size: 1.6rem; margin-bottom: 12px; }
  .hero p   { color: #65676b; margin-bottom: 28px; font-size: 1rem; line-height: 1.6; }

  /* ── Empty state ── */
  .empty { color: #65676b; font-size: .95rem; text-align: center; padding: 32px 0; }

  /* ── Global loading overlay ── */
  #global-loading {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 16px;
    color: #fff;
    font-size: 1rem;
  }
  #global-loading.visible { display: flex; }
  .gl-spinner {
    width: 44px; height: 44px;
    border: 4px solid rgba(255,255,255,.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: gl-spin .8s linear infinite;
  }
  @keyframes gl-spin { to { transform: rotate(360deg); } }
</style>
