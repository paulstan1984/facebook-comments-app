# ── Facebook App credentials ──────────────────────────────────────────────────
# From https://developers.facebook.com → Your App → Settings → Basic
FB_APP_ID=your_facebook_app_id_here
FB_APP_SECRET=your_facebook_app_secret_here

# The URL Facebook redirects to after login.
# In production: https://<your-app>.fly.dev/auth/facebook/callback
# In development: http://localhost:3000/auth/facebook/callback
FB_REDIRECT_URI=https://facebook-comments-app.fly.dev/auth/facebook/callback

# Random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
